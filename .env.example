# Copy to `.env.local` and fill in values. Next.js loads `.env.local` automatically.
#
# Anthropic (AI-generated quizzes):
# 1) https://console.anthropic.com/settings/keys — create an API key
# 2) Put it in `.env.local` as ANTHROPIC_API_KEY=sk-ant-...
# 3) Restart `npm run dev` after any change here.

ANTHROPIC_API_KEY=

# Optional — force one model id; otherwise the app tries Sonnet models in order until one works.
# ANTHROPIC_QUIZ_MODEL=claude-opus-4-6

# Optional — saved topics & scores across devices
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
